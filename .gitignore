## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/
artifacts/
publish/

# Visual Studio cache directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build log files
*.log

# Coverage and test output
coverage/
*.coverage
*.coveragexml

# Visual Studio Code data
.vscode/

# JetBrains Rider / ReSharper
.idea/
_ReSharper*/
*.DotSettings.user

# NuGet
packages/
*.nupkg
*.snupkg

# Generated publish / installer output
app.publish/
*.appx
*.appxbundle
*.msix
*.msixbundle

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Project-specific overrides
*.settings.json
